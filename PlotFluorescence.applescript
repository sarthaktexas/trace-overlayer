-- Plot Plate Fluorescence (Quick Action)
-- The Python script is embedded as base64 and written to a temp file at runtime.
-- Set "Workflow receives: Files or Folders" in "Finder.app" in Automator.

-- The full plot_plate_fluorescence.py, base64-encoded.
property encodedScript : ""

on run {input, parameters}
	repeat with f in input
		set csvPath to POSIX path of f
		if csvPath ends with ".csv" then runPlot(csvPath)
	end repeat
	return input
end run

on resolveUv()
	set home to POSIX path of (path to home folder)
	set candidates to {home & ".local/bin/uv", "/opt/homebrew/bin/uv", "/usr/local/bin/uv"}
	repeat with c in candidates
		if (do shell script "test -x " & quoted form of c & " && echo yes || echo no") is "yes" then
			return c
		end if
	end repeat

	-- uv not found; install it, then resolve again
	do shell script "curl -LsSf https://astral.sh/uv/install.sh | sh"
	set installedPath to home & ".local/bin/uv"
	if (do shell script "test -x " & quoted form of installedPath & " && echo yes || echo no") is "yes" then
		return installedPath
	end if

	error "Could not install uv. Please install it manually: curl -LsSf https://astral.sh/uv/install.sh | sh"
end resolveUv

on runPlot(csvPath)
	set uvBin to resolveUv()

	set tmpScript to "/tmp/plot_plate_fluorescence.py"
	do shell script "echo " & quoted form of encodedScript & " | base64 --decode > " & quoted form of tmpScript

	set cmd to "export LANG=en_US.UTF-8; export LC_ALL=en_US.UTF-8; " & quoted form of uvBin & " run " & quoted form of tmpScript & " " & quoted form of csvPath & " 2>&1"
	do shell script cmd

	set stem to do shell script "basename " & quoted form of csvPath & " .csv"

	display notification "Saved " & stem & ".png" ¬
		with title "Fluorescence Plot Done" sound name "Glass"
end runPlot

				<key>ActionName</key>
				<string>Run AppleScript</string>
				<key>ActionParameters</key>
				<dict>
					<key>source</key>
					<string>-- Plot Plate Fluorescence (Quick Action)
-- The Python script is embedded as base64 and written to a temp file at runtime.
-- Set "Workflow receives: Files or Folders" in "Finder.app" in Automator.

property uvBin : "/Users/sarthakmohanty/.local/bin/uv"

-- The full plot_plate_fluorescence.py, base64-encoded.
property encodedScript : ""

on run {input, parameters}
	repeat with f in input
		set csvPath to POSIX path of f
		if csvPath ends with ".csv" then runPlot(csvPath)
	end repeat
	return input
end run

on runPlot(csvPath)
	-- Write the embedded script to a temp file
	set tmpScript to "/tmp/plot_plate_fluorescence.py"
	do shell script "echo " &amp; quoted form of encodedScript &amp; " | base64 --decode &gt; " &amp; quoted form of tmpScript

	set cmd to quoted form of uvBin &amp; " run " &amp; quoted form of tmpScript &amp; " " &amp; quoted form of csvPath &amp; " 2&gt;&amp;1"
	do shell script cmd

	set stem to do shell script "basename " &amp; quoted form of csvPath &amp; " .csv"
	set outDir to do shell script "dirname " &amp; quoted form of csvPath
	set pngPath to outDir &amp; "/" &amp; stem &amp; ".png"

	display notification "Saved " &amp; stem &amp; ".png" ¬
		with title "Fluorescence Plot Done" sound name "Glass"

end runPlot</string>
				</dict>
